# ============================================
# Legal AI Agent — Environment Variables
# Copy this to .env and fill in your values
# ============================================

# === Database (auto-configured with Docker Compose) ===
POSTGRES_USER=legalai
POSTGRES_PASSWORD=legalai2026
POSTGRES_DB=legalai
DB_PORT=5432

# === App ===
APP_PORT=8080
SECRET_KEY=change-me-to-random-string
JWT_SECRET=change-me-to-random-jwt-secret

# === AI Provider (at least one required) ===
# Anthropic Claude (recommended)
ANTHROPIC_API_KEY=sk-ant-xxx

# OpenAI (optional)
# OPENAI_API_KEY=sk-xxx

# Google Gemini (optional)
# GOOGLE_API_KEY=AIza-xxx

# === For Supabase Cloud (optional, if not using Docker DB) ===
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_DB_HOST=db.your-project.supabase.co
# SUPABASE_DB_PORT=5432
# SUPABASE_DB_PASSWORD=your-password
# SUPABASE_SERVICE_KEY=eyJxxx
# SUPABASE_ANON_KEY=eyJxxx
# SUPABASE_JWT_SECRET=your-jwt-secret

# === CrawlKit (for web crawling) ===
# Get your free API key at https://crawlkit.org
# Free tier: 100 requests/day
# CRAWLKIT_API_KEY=ck_free_xxx

# === Contact & Booking Integrations (optional) ===
# Contact email shown in UI
# CONTACT_EMAIL=contact@coach.io.vn

# Cal.com booking
# CAL_EVENT_LINK=https://cal.com/legal-ai-agent/30min
# CAL_API_KEY=cal_xxx

# Resend (Email CRM)
# RESEND_API_KEY=re_xxx
