# ============================================
# Legal AI Agent — Environment Variables
# Copy this to .env and fill in your values
# ============================================

# === Database (auto-configured with Docker Compose) ===
POSTGRES_USER=legalai
POSTGRES_PASSWORD=legalai2026
POSTGRES_DB=legalai
DB_PORT=5432

# === App ===
APP_PORT=8080
SECRET_KEY=change-me-to-random-string
JWT_SECRET=change-me-to-random-jwt-secret

# Comma-separated list of exact frontend origins allowed by CORS
# Example: http://localhost:3000,https://legal-ai-agent.coach.io.vn,https://your-custom-domain.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,https://legal-ai-agent.coach.io.vn

# Regex for preview/staging domains (optional)
# Keep this if you still use Pages previews; otherwise leave empty
ALLOWED_ORIGIN_REGEX=^https://.*\.pages\.dev$

# Production DB note:
# For managed Postgres/Supabase, set DB_SSL_MODE=require
# For Docker internal db service, set DB_SSL_MODE=disable

# Frontend runtime API base (optional)
# If frontend and backend are on different domains, append ?api_base=https://api.your-domain.com
# once to app/admin URL; value will be saved in localStorage (LEGAL_API_BASE_URL).

# === AI Provider (at least one required) ===
# Anthropic Claude (recommended)
ANTHROPIC_API_KEY=sk-ant-xxx

# OpenAI (optional)
# OPENAI_API_KEY=sk-xxx

# Google Gemini (optional)
# GOOGLE_API_KEY=AIza-xxx

# === For Supabase Cloud (optional, if not using Docker DB) ===
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_DB_HOST=db.your-project.supabase.co
# SUPABASE_DB_PORT=5432
# SUPABASE_DB_PASSWORD=your-password
# DB_NAME=postgres
# DB_USER=postgres
# DB_SSL_MODE=require
# SUPABASE_SERVICE_KEY=eyJxxx
# SUPABASE_ANON_KEY=eyJxxx
# SUPABASE_JWT_SECRET=your-jwt-secret

# === CrawlKit (for web crawling) ===
# Get your free API key at https://crawlkit.org
# Free tier: 100 requests/day
# CRAWLKIT_API_KEY=ck_free_xxx
