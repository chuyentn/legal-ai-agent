# ============================================
# Legal AI Agent - Production Environment Template
# Domain: https://legal-ai-agent.coach.io.vn
# ============================================

# Runtime mode
ENV=production

# App
APP_PORT=8080
SECRET_KEY=replace-with-long-random-secret
SUPABASE_JWT_SECRET=replace-with-long-random-jwt-secret-min-32-chars
API_KEY_SECRET=replace-with-long-random-hmac-secret

# CORS / Domain
ALLOWED_ORIGINS=https://legal-ai-agent.coach.io.vn
# Keep empty if not using preview domains
ALLOWED_ORIGIN_REGEX=

# Database (required for contracts, documents, legal search data library)
SUPABASE_DB_HOST=replace-with-db-host
SUPABASE_DB_PORT=5432
SUPABASE_DB_PASSWORD=replace-with-db-password
DB_NAME=postgres
DB_USER=postgres
# Managed Postgres/Supabase: require | Docker internal db: disable
DB_SSL_MODE=require

# Supabase API/storage (optional but recommended)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=replace-with-service-role-key
SUPABASE_ANON_KEY=replace-with-anon-key

# AI Providers (at least one)
ANTHROPIC_API_KEY=replace-with-anthropic-key
OPENAI_API_KEY=
GOOGLE_API_KEY=
CLAUDE_OAUTH_TOKEN=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Multi-LLM provider encryption key
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
LLM_ENCRYPTION_KEY=replace-with-fernet-key

# OAuth (optional; needed only for OAuth provider connect flow)
OAUTH_REDIRECT_URI=https://legal-ai-agent.coach.io.vn/v1/llm/oauth/callback
OPENAI_CLIENT_ID=
OPENAI_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional crawler
CRAWLKIT_API_KEY=

# Optional uploads path (defaults to /tmp/legal-ai-agent-uploads)
UPLOAD_DIR=/tmp/legal-ai-agent-uploads

# Optional hardening
# ADMIN_IP_WHITELIST=1.2.3.4,5.6.7.8
